{
  "version": 2,
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "npm install --legacy-peer-deps && cd frontend && npm install --legacy-peer-deps",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/build/$1"
    },
    {
      "src": "/",
      "dest": "frontend/build/index.html"
    }
  ]
}
